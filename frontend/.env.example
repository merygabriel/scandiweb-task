# Point to your PHP backend GraphQL endpoint (only if not using default proxy).
# Local dev (vite): defaults to /graphql with proxy to backend — see vite.config.js
# VITE_GRAPHQL_URL=http://localhost:8084/graphql
#
# Vercel / production: set this in the Vercel project Environment Variables to your
# deployed API origin (CORS must allow your Vercel domain; this repo's PHP sets *).
# VITE_GRAPHQL_URL=https://your-api.example.com/graphql
